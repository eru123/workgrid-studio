{
  "name": "WorkGrid Light",
  "type": "light",
  "colors": {
    "editor.background":                  "#ffffff",
    "editor.foreground":                  "#333333",
    "editor.lineHighlightBackground":     "#f5f5f5",
    "editor.selectionBackground":         "#add6ff",
    "editor.inactiveSelectionBackground": "#e5ebf1",
    "editorCursor.foreground":            "#333333",
    "editorLineNumber.foreground":        "#999999",
    "editorLineNumber.activeForeground":  "#333333",
    "editorGutter.background":            "#ffffff",
    "editorIndentGuide.background":       "#d3d3d3",
    "editorIndentGuide.activeBackground": "#939393",

    "activityBar.background":             "#2c2c2c",
    "activityBar.foreground":             "#ffffff",
    "activityBar.inactiveForeground":     "#ffffff66",
    "activityBar.activeBorder":           "#0078d4",
    "activityBar.border":                 "#e4e4e4",

    "sideBar.background":                 "#f3f3f3",
    "sideBar.foreground":                 "#333333",
    "sideBar.border":                     "#e4e4e4",
    "sideBarTitle.foreground":            "#6f6f6f",
    "sideBarSectionHeader.background":    "#e8e8e8",
    "sideBarSectionHeader.foreground":    "#6f6f6f",
    "sideBarSectionHeader.border":        "#e4e4e4",

    "tab.activeBackground":               "#ffffff",
    "tab.activeForeground":               "#333333",
    "tab.activeBorderTop":                "#0078d4",
    "tab.inactiveBackground":             "#ececec",
    "tab.inactiveForeground":             "#33333380",
    "tab.border":                         "#f3f3f3",
    "tab.hoverBackground":                "#f0f0f0",
    "tab.unfocusedActiveBackground":      "#ffffff",
    "editorGroupHeader.tabsBackground":   "#f3f3f3",
    "editorGroupHeader.tabsBorder":       "#e4e4e4",

    "statusBar.background":               "#0078d4",
    "statusBar.foreground":               "#ffffff",
    "statusBar.border":                   "#0078d4",
    "statusBar.hoverBackground":          "#0062a3",
    "statusBar.itemHoverBackground":      "#ffffff1a",

    "panel.background":                   "#ffffff",
    "panel.border":                       "#e4e4e4",
    "panelTitle.activeForeground":        "#333333",
    "panelTitle.inactiveForeground":      "#33333399",
    "panelTitle.activeBorder":            "#0078d4",

    "input.background":                   "#ffffff",
    "input.foreground":                   "#333333",
    "input.border":                       "#cecece",
    "input.placeholderForeground":        "#767676",
    "inputOption.activeBorder":           "#0078d4",

    "button.background":                  "#0078d4",
    "button.foreground":                  "#ffffff",
    "button.hoverBackground":             "#006cbd",
    "button.secondaryBackground":         "#5f6a79",
    "button.secondaryForeground":         "#ffffff",
    "button.secondaryHoverBackground":    "#4c5561",

    "dropdown.background":                "#ffffff",
    "dropdown.foreground":                "#333333",
    "dropdown.border":                    "#cecece",

    "list.hoverBackground":               "#e8e8e8",
    "list.hoverForeground":               "#333333",
    "list.activeSelectionBackground":     "#0060c0",
    "list.activeSelectionForeground":     "#ffffff",
    "list.inactiveSelectionBackground":   "#e4e6f1",
    "list.inactiveSelectionForeground":   "#333333",
    "list.focusBackground":               "#d6ebff",
    "list.focusForeground":               "#333333",
    "tree.indentGuidesStroke":            "#a9a9a9",

    "badge.background":                   "#0078d4",
    "badge.foreground":                   "#ffffff",

    "scrollbarSlider.background":         "#64646466",
    "scrollbarSlider.hoverBackground":    "#646464b3",
    "scrollbarSlider.activeBackground":   "#00000099",

    "menu.background":                    "#ffffff",
    "menu.foreground":                    "#333333",
    "menu.selectionBackground":           "#0060c0",
    "menu.selectionForeground":           "#ffffff",
    "menu.separatorBackground":           "#d4d4d4",
    "menu.border":                        "#d4d4d4",

    "focusBorder":                        "#0078d4",
    "foreground":                         "#333333",
    "widget.shadow":                      "#00000026",
    "selection.background":               "#add6ff",

    "dataGrid.background":                "#ffffff",
    "dataGrid.headerBackground":          "#f3f3f3",
    "dataGrid.headerForeground":          "#333333",
    "dataGrid.rowHoverBackground":        "#f0f0f0",
    "dataGrid.selectedRowBackground":     "#d6ebff",
    "dataGrid.selectedRowForeground":     "#333333",
    "dataGrid.gridLine":                  "#e4e4e4",
    "dataGrid.nullForeground":            "#999999",
    "dataGrid.blobForeground":            "#0451a5"
  },
  "tokenColors": [
    { "scope": "keyword",                  "settings": { "foreground": "#0000ff" } },
    { "scope": "keyword.operator",         "settings": { "foreground": "#333333" } },
    { "scope": "keyword.control",          "settings": { "foreground": "#af00db" } },
    { "scope": "string",                   "settings": { "foreground": "#a31515" } },
    { "scope": "string.quoted",            "settings": { "foreground": "#a31515" } },
    { "scope": "comment",                  "settings": { "foreground": "#008000", "fontStyle": "italic" } },
    { "scope": "comment.line",             "settings": { "foreground": "#008000", "fontStyle": "italic" } },
    { "scope": "comment.block",            "settings": { "foreground": "#008000", "fontStyle": "italic" } },
    { "scope": "number",                   "settings": { "foreground": "#098658" } },
    { "scope": "constant.numeric",         "settings": { "foreground": "#098658" } },
    { "scope": "constant.language",        "settings": { "foreground": "#0000ff" } },
    { "scope": "operator",                 "settings": { "foreground": "#333333" } },
    { "scope": "punctuation",              "settings": { "foreground": "#333333" } },
    { "scope": "function",                 "settings": { "foreground": "#795e26" } },
    { "scope": "entity.name.function",     "settings": { "foreground": "#795e26" } },
    { "scope": "support.function",         "settings": { "foreground": "#795e26" } },
    { "scope": "variable",                 "settings": { "foreground": "#001080" } },
    { "scope": "variable.other",           "settings": { "foreground": "#001080" } },
    { "scope": "type",                     "settings": { "foreground": "#267f99" } },
    { "scope": "entity.name.type",         "settings": { "foreground": "#267f99" } },
    { "scope": "support.type",             "settings": { "foreground": "#267f99" } },
    { "scope": "constant",                 "settings": { "foreground": "#0070c1" } },
    { "scope": "tag",                      "settings": { "foreground": "#800000" } },
    { "scope": "attribute.name",           "settings": { "foreground": "#ff0000" } },
    { "scope": "attribute.value",          "settings": { "foreground": "#0000ff" } }
  ],
  "transforms": {
    "button.hoverBackground":   { "base": "button.background",   "fn": "darken", "amount": 0.1  },
    "list.hoverBackground":     { "base": "editor.background",   "fn": "darken", "amount": 0.05 },
    "statusBar.hoverBackground":{ "base": "statusBar.background","fn": "darken", "amount": 0.08 }
  }
}
