    "activityBar.activeBorder":           "#0078d4",
    "activityBar.border":                 "#3c3c3c",

    "sideBar.background":                 "#252526",
    "sideBar.foreground":                 "#cccccc",
    "sideBar.border":                     "#3c3c3c",
