{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WorkGrid Studio",
  "version": "0.1.4",
  "identifier": "com.skiddph.workgrid-studio",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WorkGrid Studio",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src ipc://localhost https://wgs-updater.skiddph.com; font-src 'self' data:; media-src 'none'; object-src 'none'; base-uri 'self'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://wgs-updater.skiddph.com/api/update/{{target}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENBMUFCNzlGNTg1NUYwOTEKUldTUjhGVlluN2NheW83ZTUxUjFRN2NkdEdTMFdmMjJ3ZERNc29KN3dXRWR3SXhGRWVjblVTQzgK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
