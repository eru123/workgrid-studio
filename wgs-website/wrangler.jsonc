{
  "name": "wgs-website",
  "compatibility_date": "2026-03-15",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "build": {
    "command": "pnpm install --frozen-lockfile && pnpm build"
  },
  "routes": [
    {
      "pattern": "workgrid-studio.skiddph.com",
      "custom_domain": true
    }
  ]
}