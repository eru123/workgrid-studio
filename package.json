{
  "name": "workgrid-studio",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "pnpm version:sync && pnpm version:check",
    "build": "tsc && vite build",
